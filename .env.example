# Copy this file to ".env" and fill in values. Never commit the real .env.

# ---- Google Sheets sync (optional) ----
# Two ways to provide the service-account key (free to create in Google Cloud).
# Either set GOOGLE_SHEETS_CRED to a JSON file path (local dev), OR paste the whole
# JSON content into GOOGLE_SHEETS_CRED_JSON (CI / autopilot). Share the target sheet
# with the service-account email as Editor.
GOOGLE_SHEETS_CRED=
GOOGLE_SHEETS_CRED_JSON=
GOOGLE_SHEETS_NAME=Air Ocean Leads
# Append-only sync target (the team's Sales_Review CRM). The 19EXC... id from the URL.
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=Sales_Review
# Other tab(s) to de-dup against (comma-separated), e.g. a master "Leads" tab — a
# lead already present there is never re-added to the target tab.
GOOGLE_SHEET_DEDUP_TABS=Leads

# ---- Performance (optional; the autopilot sets these) ----
AOL_MAX_WORKERS=1          # search concurrency (>1 parallelises sources)
AOL_HTTP_POOL=             # "1" to reuse a pooled HTTP session
AOL_HTTP_CACHE_DIR=        # dir to cache fetched pages (speeds up repeat runs)

# ---- Feature flags for DEFERRED (RED-zone) scrapers ----
# These sources violate platform Terms of Service and may conflict with Egypt's
# PDPL. They are OFF by default. Enable ONLY if you accept the legal/ban risk.
FEATURE_FACEBOOK=false
FEATURE_INSTAGRAM=false
FEATURE_LINKEDIN=false
FEATURE_TRUECALLER=false

# ---- Defaults ----
DEFAULT_COUNTRY=Egypt
DEFAULT_REGION=EG
